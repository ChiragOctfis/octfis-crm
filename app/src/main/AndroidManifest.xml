<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permissions ──────────────────────────────────────────────────────── -->

    <!-- Basic network access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Post-call notification prompt (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Meeting check in location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- In-app call button (ACTION_CALL) -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- TelephonyCallback / PhoneStateListener (ISSUE 1, 2, 3) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- CallLog fallback for API 31+ where TelephonyCallback gives no number (ISSUE 2) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Floating overlay button after call ends (ISSUE 2) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Auto-start CallMonitorService on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Required to call startForeground() -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />


    <!-- PostCallLogActivity shown over lock screen (ISSUE 1) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Required foreground service type for phone-state monitoring on API 34+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".OctfisApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/crm_app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/crm_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Octfis">

        <!-- ── Main Activity ──────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Octfis"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="com.octfis.crm"
                    android:host="oauth"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <!--
            ISSUE 1 FIX — PostCallLogActivity
            ─────────────────────────────────
            • launchMode="singleTop"    — prevents stacking duplicate dialogs
            • excludeFromRecents="true" — invisible in the task switcher
            • showWhenLocked="true"     — appears even on the lock screen
            • turnScreenOn="true"       — wakes the screen if it is off
            These four attributes together ensure the dialog fires immediately
            after the call ends regardless of which app is in the foreground.
        -->
        <activity
            android:name=".service.PostCallLogActivity"
            android:exported="false"
            android:theme="@style/Theme.Octfis.Dialog"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <!--
            CallMonitorService
            ──────────────────
            foregroundServiceType="phoneCall" is required on API 34+
            for a service that reads phone state.
        -->
        <service
            android:name=".service.CallMonitorService"
            android:foregroundServiceType="dataSync"
            android:exported="false"
             />

        <!--
            BootReceiver — restarts CallMonitorService after device reboot.
            QUICKBOOT_POWERON is the MIUI fast-boot equivalent.
        -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>